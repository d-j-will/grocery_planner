# Template for /root/grocery_planner/.env on the Docker host.
# Never commit a filled copy. Copy to .env and replace every CHANGE_ME.

# ── GHCR image namespace ─────────────────────────────────────────────────────
# The owner the deploy workflow pushed images under; must equal the repo owner
# (${{ github.repository_owner }}). Compose reads ghcr.io/${IMAGE_OWNER}/...
IMAGE_OWNER=d-j-will

# ── Postgres (container bootstrap) ──────────────────────────────────────────
POSTGRES_USER=grocery_planner
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=grocery_planner_prod

# ── App ─────────────────────────────────────────────────────────────────────
# Must agree with POSTGRES_* above; host "postgres" is the compose service name.
DATABASE_URL=ecto://grocery_planner:CHANGE_ME@postgres/grocery_planner_prod
# mix phx.gen.secret
SECRET_KEY_BASE=CHANGE_ME
POOL_SIZE=10

# ── OpenTelemetry (wired by ticket t7j — placeholders until then) ───────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://<homelab-collector>:4318
# OTEL_SERVICE_NAME=grocery-planner
